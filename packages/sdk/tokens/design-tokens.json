{
  "$schema": "https://vibeful.ai/design-tokens/v1",
  "name": "Vibeful Design Tokens",
  "version": "1.0.0",
  "description": "Design tokens for the Vibeful SDK — agent branding, chat widget, and AMS",
  "colors": {
    "primary": {
      "50": "#eff6ff",
      "100": "#dbeafe",
      "200": "#bfdbfe",
      "300": "#93c5fd",
      "400": "#60a5fa",
      "500": "#3b82f6",
      "600": "#2563eb",
      "700": "#1d4ed8",
      "800": "#1e40af",
      "900": "#1e3a8a"
    },
    "neutral": {
      "50": "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "800": "#1f2937",
      "900": "#111827"
    },
    "success": { "500": "#22c55e", "600": "#16a34a" },
    "warning": { "500": "#f59e0b", "600": "#d97706" },
    "error": { "500": "#ef4444", "600": "#dc2626" },
    "info": { "500": "#3b82f6", "600": "#2563eb" }
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.75"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem"
  },
  "radii": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",
    "lg": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)"
  },
  "components": {
    "chat": {
      "userBubble": {
        "background": "{colors.primary.600}",
        "text": "#ffffff",
        "radius": "12px",
        "padding": "0.5rem 0.75rem"
      },
      "botBubble": {
        "background": "{colors.neutral.100}",
        "text": "{colors.neutral.900}",
        "radius": "12px",
        "padding": "0.5rem 0.75rem"
      },
      "input": {
        "background": "#ffffff",
        "border": "{colors.neutral.300}",
        "text": "{colors.neutral.900}",
        "placeholder": "{colors.neutral.400}",
        "radius": "8px"
      },
      "sendButton": {
        "background": "{colors.primary.600}",
        "text": "#ffffff",
        "radius": "8px"
      }
    },
    "widgets": {
      "table": { "headerBg": "{colors.neutral.50}", "border": "{colors.neutral.200}" },
      "chart": { "barGap": "0.5rem" },
      "card": { "border": "{colors.neutral.200}", "radius": "{radii.lg}" }
    },
    "ams": {
      "sidebar": { "background": "{colors.neutral.800}", "text": "#ffffff" },
      "tab": { "active": "{colors.primary.600}", "inactive": "{colors.neutral.400}" }
    }
  },
  "cssVariables": {
    "--vibeful-user-bg": "{components.chat.userBubble.background}",
    "--vibeful-user-text": "{components.chat.userBubble.text}",
    "--vibeful-bot-bg": "{components.chat.botBubble.background}",
    "--vibeful-bot-text": "{components.chat.botBubble.text}",
    "--vibeful-send-bg": "{components.chat.sendButton.background}",
    "--vibeful-border": "{colors.neutral.300}",
    "--vibeful-input-bg": "{components.chat.input.background}",
    "--vibeful-input-text": "{components.chat.input.text}",
    "--vibeful-radius": "{radii.md}",
    "--vibeful-font": "{typography.fontFamily}",
    "--vibeful-shadow": "{shadows.md}"
  }
}
