# ── Vibeful Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# All variables are read by Docker Compose and passed to services.
# After editing .env, restart: docker compose down && docker compose up -d

# ── LLM Provider (required) ───────────────────────────────────
# Get a key at https://platform.deepseek.com/api_keys
# Free tier available — no credit card required to start.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Alternative LLM provider (optional)
# Set to 'openai' to use OpenAI instead. Requires OPENAI_API_KEY.
# VIBEFUL_LLM_PROVIDER=deepseek

# ── Database ───────────────────────────────────────────────────
# PostgreSQL connection. Defaults work for local Docker.
DATABASE_URL=postgresql://vibeful:vibeful_dev@localhost:5432/vibeful

# Redis connection. Defaults work for local Docker.
REDIS_URL=redis://localhost:6379

# ── Ports ──────────────────────────────────────────────────────
GRPC_PORT=50051
REST_PORT=50052

# ── Authentication (optional — skip for local/dev) ────────────
# API keys for accessing the REST API.
# Format: key:name,key:name
# VIBEFUL_API_KEYS=sk-local-dev-123:Admin

# Auth provider: api_key, jwt, or passthrough (no auth)
# VIBEFUL_AUTH_PROVIDER=passthrough

# ── Rate Limiting (optional) ──────────────────────────────────
# Requests per minute per IP. Default: unlimited in dev.
# VIBEFUL_RATE_LIMIT_REQUESTS=100

# ── Observability (optional) ──────────────────────────────────
# CORS origins for browser access (comma-separated)
# VIBEFUL_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
