# Vibeful CI — Optional GitHub Actions workflow.
#
# THIS FILE IS OPTIONAL. Vibeful CI is designed to run locally:
#   make ci          (Linux/macOS)
#   ./scripts/ci.ps1 (Windows)
#   ./scripts/ci.sh  (Any OS)
#
# You do NOT need GitHub Actions to run CI. All checks run on your
# local hardware for free. This file is provided as a convenience
# if you choose to use GitHub Actions.
#
# To disable: delete this file or rename it to ci.yml.disabled.
# To adapt for GitLab CI: see .gitlab-ci.yml.example.
#
# Cost note: GitHub Actions free tier includes 2,000 minutes/month
# for private repos. Public repos get unlimited minutes.

name: CI

on:
  push:
    branches: [master, main]
  pull_request:
    branches: [master, main]

jobs:
  ci:
    runs-on: ubuntu-latest
    timeout-minutes: 15

    services:
      postgres:
        image: pgvector/pgvector:pg16
        env:
          POSTGRES_USER: vibeful
          POSTGRES_PASSWORD: vibeful_dev
          POSTGRES_DB: vibeful
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: Install dependencies
        run: make setup

      - name: Run CI pipeline
        run: make ci
        env:
          DATABASE_URL: postgresql://vibeful:vibeful_dev@localhost:5432/vibeful
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
